{
  "name": "conquest-game",
  "version": "1.0.0",
  "description": "A browser-based strategy game similar to Risk",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "client": "http-server public -p 3001 -c-1"
  },
  "keywords": ["game", "strategy", "multiplayer", "typescript"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "http-server": "^14.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}